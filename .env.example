DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chess_puzzles
PORT=3001
LOG_LEVEL=info
PUBLIC_API_BASE_URL=https://api.yourdomain.com

# x402 Pay-Per-Use (Celo)
X402_ENABLED=true
X402_NETWORKS=celo,base
X402_PRICE_USD_PER_PUZZLE=0.01
# Legacy fallback (used when X402_PRICE_USD_PER_PUZZLE is unset)
X402_PRICE_USD=0.01
X402_CHALLENGE_TTL_SECONDS=600
X402_ACCEPTED_TOKENS=USDC
X402_CELO_PAY_TO_ADDRESS=
X402_BASE_PAY_TO_ADDRESS=
X402_CELO_RPC_URL=https://forno.celo.org
X402_BASE_RPC_URL=https://mainnet.base.org
X402_CELO_USDC_TOKEN_ADDRESS=
X402_BASE_USDC_TOKEN_ADDRESS=
